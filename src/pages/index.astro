---
import Layout from "../layouts/Layout.astro";
import Sidebar from "../components/Sidebar.astro";
import SectionHeading from "../components/SectionHeading.astro";
import ProjectCard from "../components/ProjectCard.astro";
import ExperienceCard from "@components/ExperienceCard.astro";
---

<Layout title="Ayush Gupta">
	<Sidebar slot="sidebar" />

	<!-- HERO -->
	<section
		id="hero"
		class="min-h-screen grid md:grid-cols-2 items-center gap-12"
	>
		<div>
			<p class="text-accent font-mono mb-4">Hi, my name is</p>
			<h1
				class="group relative w-fit text-4xl md:text-6xl font-heading font-bold mb-4"
			>
				<span
					class="relative z-10 transition-colors duration-300 group-hover:text-white"
				>
					Ayush
				</span>

				<span
					class="pointer-events-none absolute inset-0 opacity-0 group-hover:opacity-100
           		transition-opacity duration-300"
				>
					<span
						class="absolute inset-0 text-accent blur-[1px]
					group-hover:animate-[glow-flicker_0.7s_ease-out_0.05s]"
					>
						Ayush
					</span>

					<span
						class="absolute inset-0 text-accent/70 blur-[6px]
					group-hover:animate-[glow-flicker_0.7s_ease-out_0.05s]"
					>
						Ayush
					</span>
				</span>
			</h1>
			<p class="text-muted max-w-xl">
				I build clean, performant web applications with a focus on
				simplicity and usability.
			</p>
		</div>

		<div class="hidden md:flex items-center justify-center">
			<div class="group relative w-full flex justify-center items-center">
				<div
					class="relative text-xs font-heading text-muted border border-white/10 rounded-md p-4
             bg-surface/60 backdrop-blur-sm group-hover:border-white/20 transition-colors duration-300"
				>
					<p
						class="opacity-70 group-hover:opacity-100 transition duration-300"
					>
						$ whoami<span
							class="ml-1 animate-[blink_1s_step-end_infinite]"
							>_</span
						>
					</p>
					<p
						class="text-foreground opacity-80 group-hover:opacity-100 transition duration-300 delay-75"
					>
						ayushgpt01 (Ayush Gupta)
					</p>
					<p
						class="mt-2 opacity-70 group-hover:opacity-100 transition duration-300 delay-150"
					>
						$ stack
					</p>
					<p
						class="opacity-70 group-hover:opacity-100 transition duration-300 delay-200"
					>
						react • java • go • postgres • aws
					</p>

					<div
						class="pointer-events-none absolute -inset-10 opacity-60"
						style="
								background: radial-gradient(
									circle at center,
									rgba(16,185,129,0.15),
									transparent 70%
								);"
					>
					</div>
				</div>
			</div>
		</div>
	</section>

	<!-- EXPERIENCE -->
	<section id="experience" class="py-section">
		<SectionHeading title="Experience" />
		<div
			class="flex flex-col gap-1.5 relative"
			data-spotlight-container
			style="--x: 50%; --y: 50%;"
		>
			<ExperienceCard
				title="Software Developer"
				company="Busibud"
				range="2023 - Present"
				description="Handle end-to-end development cycle"
				tech={[
					"React",
					"Typescript",
					"Java",
					"Spring",
					"Laravel",
					"Postgres",
				]}
			/>
		</div>
	</section>

	<!-- PROJECTS -->
	<section id="projects" class="py-section">
		<SectionHeading title="Projects" />

		<div
			class="grid md:grid-cols-2 gap-6 relative"
			data-spotlight-container
			style="--x: 50%; --y: 50%;"
		>
			<ProjectCard
				title="Chat App"
				description="Real-time chat using WebSockets."
				tech={["Go", "React", "AWS", "WebSockets", "Postgres"]}
				link="https://ayushgpt01.com"
			/>

			<ProjectCard
				title="Portfolio"
				description="Minimal portfolio built using Astro. (You are currently visiting this)"
				tech={["Astro", "Tailwind"]}
			/>

			<ProjectCard
				title="Other Projects"
				description="Check my github for other projects I am working on."
				tech={[]}
				link="https://github.com/ayushgpt01?tab=repositories"
			/>
		</div>
	</section>

	<!-- CONTACT -->
	<section id="contact" class="py-section mb-32">
		<SectionHeading title="Contact" />

		<p class="text-muted mb-6">Open to opportunities and collaborations.</p>

		<div class="flex items-center gap-4">
			<a
				href="mailto:ayushgpt043@gmail.com"
				class="inline-block border border-accent text-accent px-6 py-3 rounded hover:text-white
			hover:bg-accent/10 transition duration-300"
			>
				Say Hello
			</a>

			<a
				href="/resume.pdf"
				target="_blank"
				class="text-sm text-muted hover:text-foreground transition flex items-center gap-1"
			>
				View Resume
				<span class="text-xs">↗</span>
			</a>
		</div>
	</section>

	<div class="mt-24 pt-6 border-t border-white/5">
		<p class="text-xs font-mono flex flex-wrap items-center gap-x-2">
			<span class="text-muted/70">built with</span>

			<a
				href="https://astro.build/"
				class="text-muted hover:text-foreground transition
			hover:[text-shadow:0_0_6px_rgba(16,185,129,0.6)]"
				target="_blank"
				rel="noopener noreferrer"
			>
				astro
			</a>
			<span class="text-muted/40">•</span>

			<a
				href="https://tailwindcss.com/"
				class="text-muted hover:text-foreground transition
			hover:[text-shadow:0_0_6px_rgba(16,185,129,0.6)]"
				target="_blank"
				rel="noopener noreferrer"
			>
				tailwind
			</a>

			<span class="text-muted/70 ml-2">deployed on</span>

			<a
				href="https://www.cloudflare.com/"
				class="text-muted hover:text-foreground transition
			hover:[text-shadow:0_0_6px_rgba(16,185,129,0.6)]"
				target="_blank"
				rel="noopener noreferrer"
			>
				cloudflare
			</a>
		</p>
	</div>
</Layout>

<script is:inline>
	const containers = document.querySelectorAll("[data-spotlight-container]");

	containers.forEach((container) => {
		let currentX = 0;
		let currentY = 0;
		let targetX = 0;
		let targetY = 0;
		let isInside = false;

		const lerp = (a, b, n) => a + (b - a) * n;

		function update() {
			if (isInside) {
				currentX = lerp(currentX, targetX, 0.12);
				currentY = lerp(currentY, targetY, 0.12);
			}

			container.style.setProperty("--x", `${currentX}px`);
			container.style.setProperty("--y", `${currentY}px`);

			requestAnimationFrame(update);
		}

		update();

		container.addEventListener("mousemove", (e) => {
			const rect = container.getBoundingClientRect();
			targetX = e.clientX - rect.left;
			targetY = e.clientY - rect.top;
			isInside = true;
		});

		container.addEventListener("mouseleave", () => {
			isInside = false;
		});
	});
</script>

<script is:inline>
	function updateCardOffsets() {
		const containers = document.querySelectorAll(
			"[data-spotlight-container]",
		);

		containers.forEach((container) => {
			const cards = container.querySelectorAll("[data-card]");
			const containerRect = container.getBoundingClientRect();

			cards.forEach((card) => {
				const rect = card.getBoundingClientRect();

				card.style.setProperty(
					"--offset-x",
					`${rect.left - containerRect.left}px`,
				);
				card.style.setProperty(
					"--offset-y",
					`${rect.top - containerRect.top}px`,
				);
			});
		});
	}

	window.addEventListener("resize", updateCardOffsets);
	window.addEventListener("scroll", updateCardOffsets);

	requestAnimationFrame(updateCardOffsets);
</script>

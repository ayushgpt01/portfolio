---
interface Props {
    title: string;
    description: string;
    tech: string[];
}

const { title, description, tech } = Astro.props;
---

<div
    class="group relative rounded-md bg-surface border border-transparent
         transition-all duration-300 ease-out
         hover:-translate-y-1 hover:border-white/10 hover:shadow-lg"
    style="--offset-x: 0px; --offset-y: 0px;"
    data-card
>
    <!-- glow layer -->
    <div
        class="pointer-events-none absolute inset-0 rounded-md opacity-0
           transition-opacity duration-300 group-hover:opacity-100"
    >
        <div
            class="absolute inset-0 rounded-md"
            style="background: radial-gradient(
        350px circle at 
        calc(var(--x) - var(--offset-x)) 
        calc(var(--y) - var(--offset-y)),
        rgba(16,185,129,0.08),
        transparent 60%
      );"
        >
        </div>

        <div
            class="absolute inset-0 rounded-md"
            style="background: radial-gradient(
        180px circle at 
        calc(var(--x) - var(--offset-x)) 
        calc(var(--y) - var(--offset-y)),
        rgba(255,255,255,0.04),
        transparent 70%
      );"
        >
        </div>
    </div>

    <!-- content -->
    <div class="relative p-5">
        <h3
            class="text-base font-medium mb-2 transition-colors duration-200 group-hover:text-foreground"
        >
            {title}
        </h3>

        <p class="text-sm text-muted leading-relaxed mb-4">
            {description}
        </p>

        <div class="flex flex-wrap gap-2">
            {
                tech.map((t) => (
                    <span
                        class="text-[11px] px-2 py-1 rounded-md 
                   bg-[rgba(16,185,129,0.06)] 
                   text-[rgb(16,185,129)] 
                   border border-[rgba(16,185,129,0.12)] 
                   transition-all duration-200 
                   group-hover:bg-[rgba(16,185,129,0.1)] 
                   group-hover:border-[rgba(16,185,129,0.2)] 
                   group-hover:shadow-[0_0_8px_rgba(16,185,129,0.12)]"
                    >
                        {t}
                    </span>
                ))
            }
        </div>
    </div>
</div>

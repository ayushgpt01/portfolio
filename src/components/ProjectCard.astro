---
interface Props {
    title: string;
    description: string;
    tech: string[];
}

const { title, description, tech } = Astro.props;
---

<div class="bg-surface p-6 rounded-md hover:-translate-y-1 transition">
    <h3 class="text-lg font-semibold mb-2">{title}</h3>
    <p class="text-muted text-sm mb-4">{description}</p>
    <div class="text-xs text-muted font-mono">
        {tech.join(" • ")}
    </div>
</div>

---
interface Props {
    title: string;
    company: string;
    description: string;
    range: string;
    link?: string;
    tech: string[];
}

const { title, company, range, link, description, tech } = Astro.props;
---

<div
    class="group relative rounded-md bg-surface border border-transparent
         transition-all duration-300 ease-out
         hover:-translate-y-1 hover:border-white/10 hover:shadow-lg"
    style="--offset-x: 0px; --offset-y: 0px;"
    data-card
>
    <!-- glow layer -->
    <div
        class="pointer-events-none absolute inset-0 rounded-md opacity-0
           transition-opacity duration-300 group-hover:opacity-100"
    >
        <div
            class="absolute inset-0 rounded-md"
            style="background: radial-gradient(
                    400px circle at 
                    calc(var(--x) - var(--offset-x)) 
                    calc(var(--y) - var(--offset-y)),
                    rgba(16,185,129,0.12),
                    transparent 60%
                );"
        >
        </div>

        <div
            class="absolute inset-0 rounded-md"
            style="
                background: radial-gradient(
                    200px circle at 
                    calc(var(--x) - var(--offset-x)) 
                    calc(var(--y) - var(--offset-y)),
                    rgba(255,255,255,0.05),
                    transparent 70%
                );
            "
        >
        </div>
    </div>

    <!-- content -->
    <div class="relative p-5">
        <div class="flex items-center justify-between mb-1">
            <h3
                class="text-base font-medium transition-colors duration-200 group-hover:text-foreground"
            >
                {title}
            </h3>

            <span class="text-xs text-muted font-(--font-body)">
                {range}
            </span>
        </div>

        <div class="mb-3">
            {
                link ? (
                    <a
                        href={link}
                        target="_blank"
                        rel="noopener noreferrer"
                        class="text-xs text-muted flex items-center gap-1 w-fit
                   transition-all duration-200
                   hover:text-foreground hover:gap-1.5"
                    >
                        {company}
                        <span class="text-[10px] transition-transform duration-200 group-hover:translate-x-0.5 group-hover:-translate-y-0.5">
                            ↗
                        </span>
                    </a>
                ) : (
                    <p class="text-xs text-muted">{company}</p>
                )
            }
        </div>

        <p class="text-sm text-muted leading-relaxed mb-4">
            {description}
        </p>

        <div class="flex flex-wrap gap-2">
            {
                tech.map((t) => (
                    <span
                        class="text-[11px] px-2 py-1 rounded-md 
                   bg-[rgba(16,185,129,0.08)] 
                   text-[rgb(16,185,129)] 
                   border border-[rgba(16,185,129,0.15)]
                   transition-all duration-200
                   group-hover:bg-[rgba(16,185,129,0.12)]
                   group-hover:border-[rgba(16,185,129,0.25)]"
                    >
                        {t}
                    </span>
                ))
            }
        </div>
    </div>
</div>
